# ── Telegram ──────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Comma-separated list of Telegram chat IDs allowed to use the bot
# Get yours by messaging @userinfobot on Telegram
ALLOWED_CHAT_IDS=123456789,987654321

# ── Anthropic ─────────────────────────────────────────────────────────
# Get this from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google ────────────────────────────────────────────────────────────
# Path to your service account JSON key file
SERVICE_ACCOUNT_FILE=service_account.json

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# The ID of the Google Drive folder where form images are stored
# Find it in the folder URL: https://drive.google.com/drive/folders/FOLDER_ID
DRIVE_FOLDER_ID=your_drive_folder_id_here

# The tab name in your sheet (default: Sheet1)
SHEET_NAME=Sheet1
